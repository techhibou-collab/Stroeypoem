# Copy to deploy/ec2/.env and fill in values.
# Use with: docker compose --env-file deploy/ec2/.env -f docker-compose.ec2.yml up -d --build

# Strong password for SQL Server sa (must meet SQL Server complexity rules)
MSSQL_SA_PASSWORD=ChangeMe_StrongP@ssw0rd

# Backend admin JWT — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# URL the *browser* uses to call the API (include http:// or https://, no trailing slash).
# Example single EC2: http://12.34.56.78:5005
# Example behind reverse proxy later: https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP:5005

# Optional override (default poems_db)
# DB_NAME=poems_db
